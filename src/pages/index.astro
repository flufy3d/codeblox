---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProgressMap from '../components/islands/ProgressMap.svelte';
import { buildCatalog } from '../lib/server-catalog';

const catalog = await buildCatalog(import.meta.env.DEV);
---

<BaseLayout>
  <div class="mx-auto max-w-2xl px-4 pt-5 text-center">
    <h1 class="text-2xl font-black text-slate-800">🗺️ 你的冒险地图</h1>
    <p class="mt-1 text-slate-500">一关一关闯过去，做出你自己的 Roblox 游戏！</p>
  </div>
  <ProgressMap client:load catalog={catalog} />
</BaseLayout>
