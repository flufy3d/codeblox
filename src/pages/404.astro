---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/url';
---

<BaseLayout title="找不到页面">
  <div class="mx-auto flex max-w-2xl flex-col items-center justify-center gap-4 px-6 py-24 text-center">
    <h1 class="text-4xl font-black">🚧 找不到这个页面</h1>
    <p class="text-slate-600">也许它被传送到别的世界去了。</p>
    <a class="rounded-full bg-indigo-500 px-5 py-2 font-bold text-white hover:bg-indigo-600" href={withBase('/')}>← 回到首页</a>
  </div>
</BaseLayout>
