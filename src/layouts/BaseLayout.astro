---
import '../styles/global.css';
import { withBase } from '../lib/url';
import CatalogData from '../components/CatalogData.astro';
import BottomNav from '../components/BottomNav.astro';
import ProfileSwitcher from '../components/islands/ProfileSwitcher.svelte';
import XPBar from '../components/islands/XPBar.svelte';

interface Props {
  title?: string;
}
const { title } = Astro.props;
const fullTitle = title ? `${title} · CodeBlox` : 'CodeBlox · 做出你自己的 Roblox 游戏';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <CatalogData />
  </head>
  <body class="min-h-screen">
    <header class="sticky top-0 z-20 border-b border-slate-100 bg-white/90 backdrop-blur">
      <div class="mx-auto flex max-w-2xl items-center justify-between gap-3 px-4 py-2">
        <a href={withBase('/')} class="flex items-center gap-2 text-lg font-black text-slate-800">
          <span>🎮</span><span>CodeBlox</span>
        </a>
        <div class="flex items-center gap-3">
          <XPBar client:load />
          <ProfileSwitcher client:load />
        </div>
      </div>
    </header>

    <main class="pb-24">
      <slot />
    </main>

    <BottomNav />
  </body>
</html>
