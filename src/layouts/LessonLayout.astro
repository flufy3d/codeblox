---
import type { CollectionEntry } from 'astro:content';
import type { CatalogLesson } from '../lib/types';
import { withBase } from '../lib/url';
import { UI } from '../lib/i18n';
import TaskChecklist from '../components/islands/TaskChecklist.svelte';
import QuizBlock from '../components/islands/QuizBlock.svelte';
import LessonCompleteButton from '../components/islands/LessonCompleteButton.svelte';

interface Props {
  entry: CollectionEntry<'lessons'>;
  prev: CatalogLesson | null;
  next: CatalogLesson | null;
}
const { entry, prev, next } = Astro.props;
const d = entry.data;
const taskIds = d.tasks.map((t) => t.id);
---

<article class="mx-auto max-w-2xl px-4 py-6">
  <a href={withBase('/')} class="text-sm font-bold text-indigo-500 hover:underline">{UI.backToMap}</a>

  <h1 class="mt-3 text-3xl font-black text-slate-800">{d.emoji} {d.title}</h1>
  <p class="mt-1 text-sm text-slate-400">约 {d.estMinutes} 分钟 · 完成 +{d.xp} XP</p>

  <div class="mt-4 rounded-2xl border-2 border-indigo-100 bg-indigo-50 px-4 py-3">
    <p class="font-bold text-indigo-700">{UI.objectivesTitle}</p>
    <ul class="mt-1 list-disc pl-5 text-slate-600">
      {d.objectives.map((o) => <li class="my-1">{o}</li>)}
    </ul>
  </div>

  <div class="lesson-prose mt-6">
    <slot />
  </div>

  {
    d.tasks.length > 0 && (
      <section class="mt-8">
        <h2 class="text-xl font-black text-slate-800">{UI.tasksTitle}</h2>
        <TaskChecklist client:load lessonId={d.id} tasks={d.tasks} />
      </section>
    )
  }

  {
    d.quiz.length > 0 && (
      <section class="mt-8">
        <h2 class="text-xl font-black text-slate-800">{UI.quizTitle}</h2>
        <QuizBlock client:load lessonId={d.id} quiz={d.quiz} />
      </section>
    )
  }

  {
    d.challenge && (
      <section class="mt-8 rounded-2xl border-2 border-amber-200 bg-amber-50 px-4 py-3">
        <p class="font-bold text-amber-700">{UI.challengeTitle}</p>
        <p class="mt-1 text-slate-600">{d.challenge}</p>
      </section>
    )
  }

  <LessonCompleteButton
    client:load
    lessonId={d.id}
    xp={d.xp}
    taskIds={taskIds}
    hasQuiz={d.quiz.length > 0}
    nextSlug={next?.slug}
  />

  <nav class="mt-6 flex items-center justify-between gap-3 text-sm font-bold">
    {
      prev ? (
        <a href={withBase('/lessons/' + prev.slug)} class="max-w-[45%] truncate text-slate-500 hover:text-indigo-500">
          ← {prev.title}
        </a>
      ) : (
        <span />
      )
    }
    {
      next ? (
        <a href={withBase('/lessons/' + next.slug)} class="max-w-[45%] truncate text-right text-slate-500 hover:text-indigo-500">
          {next.title} →
        </a>
      ) : (
        <span />
      )
    }
  </nav>
</article>

<script>
  // 配图点击放大：点 .shot-zoom 图片弹出大图，点背景 / ✕ / Esc 关闭。
  // 用事件委托挂在 document 上（跨视图过渡仍有效），覆盖层懒创建到 body。
  function initShotZoom() {
    if ((window as any).__shotZoom) return;
    (window as any).__shotZoom = true;

    function getOverlay() {
      let o = document.getElementById('shot-lightbox');
      if (o) return o;
      o = document.createElement('div');
      o.id = 'shot-lightbox';
      const btn = document.createElement('button');
      btn.className = 'shot-lightbox-close';
      btn.setAttribute('aria-label', '关闭');
      btn.textContent = '✕';
      const big = document.createElement('img');
      big.alt = '';
      o.appendChild(btn);
      o.appendChild(big);
      o.addEventListener('click', (e) => {
        const t = e.target as HTMLElement;
        if (t === o || t.classList.contains('shot-lightbox-close')) close();
      });
      document.body.appendChild(o);
      return o;
    }
    function open(src: string, alt: string) {
      const o = getOverlay();
      (o.querySelector('img') as HTMLImageElement).src = src;
      (o.querySelector('img') as HTMLImageElement).alt = alt || '';
      o.classList.add('show');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      const o = document.getElementById('shot-lightbox');
      if (o) o.classList.remove('show');
      document.body.style.overflow = '';
    }
    document.addEventListener('click', (e) => {
      const img = (e.target as HTMLElement).closest('img.shot-zoom') as HTMLImageElement | null;
      if (img) open(img.currentSrc || img.src, img.alt);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  }

  initShotZoom();
  document.addEventListener('astro:page-load', initShotZoom);
</script>
